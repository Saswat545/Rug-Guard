services:
  - type: web
    name: rugguard-api
    env: python
    region: oregon
    plan: free
    buildCommand: pip install -r requirements.txt
    startCommand: uvicorn main:app --host 0.0.0.0 --port $PORT
    envVars:
      - key: ETHERSCAN_API_KEY
        sync: false          # you enter this manually in Render dashboard
      - key: MODEL_PATH
        value: models/rugguard_v2.pkl
      - key: COLS_PATH
        value: models/feature_columns.pkl
      - key: EXPLAINER_PATH
        value: models/shap_explainer.pkl
      - key: METRICS_PATH
        value: models/metrics.json